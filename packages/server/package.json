{
  "name": "@browser-mcp/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "browser-mcp-nextgen": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean && node -e \"require('fs').chmodSync('dist/index.js',0o755)\"",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test $(find src -name '*.test.ts')",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@browser-mcp/shared": "*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^13.1.0",
    "playwright-core": "^1.52.0",
    "ws": "^8.18.1",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/ws": "^8.18.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
